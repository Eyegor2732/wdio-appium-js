{
  "name": "wdio-appium",
  "type": "module",
  "imports": {
    "#androidScreens/*": "./test/screenobjects/android/*",
    "#iosScreens/*": "./test/screenobjects/ios/*"
  },
  "devDependencies": {
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "appium": "^3.5.2",
    "appium-uiautomator2-driver": "^7.6.2",
    "chromedriver": "^146.0.6",
    "module-alias": "^2.3.4"
  },
  "scripts": {
    "test": "wdio run ./wdio.android.conf.js",
    "test:ci": "CI=1 wdio run ./wdio.android.conf.js",
    "wdio:spec": "wdio run ./wdio.android.conf.js --spec",
    "wdio:android": "wdio run ./wdio.android.conf.js",
    "wdio:android:spec": "wdio run ./wdio.android.conf.js --spec",
    "wdio:apidemos": "wdio run ./wdio.android.apidemos.conf.js",
    "wdio:apidemos:native": "wdio run ./wdio.android.apidemos.conf.js --spec ./test/specs/android-native.spec.js",
    "test:all": "npm run test && npm run wdio:apidemos",
    "wdio:add-note": "wdio run ./wdio.android.conf.js --spec ./test/specs/android/add-note-screen.spec.js",
    "wdio:webview": "wdio run ./wdio.android.conf.js --spec ./test/specs/android/webview.spec.js",
    "wdio:ios": "wdio run ./wdio.ios.conf.js",
    "wdio:ios:spec": "wdio run ./wdio.ios.conf.js --spec",
    "wdio:mobile": "wdio run ./wdio.$PLATFORM.conf.js"
  }
}